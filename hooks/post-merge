#!/usr/bin/env bash
# hooks/post-merge — auto-deploy after `git pull` / `git merge`
#
# Install (keeps hook at hooks/post-merge, path always resolves correctly):
#   git config core.hooksPath hooks
#
set -euo pipefail

LOGFILE="deploy.log"
TS="$(date '+%Y-%m-%d %H:%M:%S')"

# Resolve repo root regardless of where git stores the hook.
cd "$(git rev-parse --show-toplevel)"

log() { echo "[$TS][post-merge] $*" | tee -a "$LOGFILE" >&2; }

log "Rebuilding and restarting containers..."

# Support both Docker Compose v1 (docker-compose) and v2 (docker compose).
if docker compose version &>/dev/null 2>&1; then
    COMPOSE="docker compose"
elif docker-compose version &>/dev/null 2>&1; then
    COMPOSE="docker-compose"
else
    log "ERROR: neither 'docker compose' nor 'docker-compose' found."
    exit 1
fi

rc=0
$COMPOSE up -d --build --remove-orphans || rc=$?
if [ "$rc" -ne 0 ]; then
    log "ERROR: compose up failed (exit $rc)."
    exit 1
fi

log "Done."
